        "anthropicApi": {
          "id": "g1b8If6eUJ1a04uD",
          "name": "SmartESG"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse Herschrijver output\nconst raw = $json.output || '{}';\nconst clean = raw.replace(/```json|```/g, '').trim();\nlet parsed = {};\ntry { parsed = JSON.parse(clean); }\ncatch(e) { parsed = { post_tekst: raw, haakje: '', hashtags: [] }; }\n\nconst combine = $('Combine for Rewrite').first().json;\n\nreturn {\n  json: {\n    post_id: combine.post_id,\n    post_tekst: parsed.post_tekst || '',\n    haakje: parsed.haakje || '',\n    hashtags: Array.isArray(parsed.hashtags) ? parsed.hashtags.join(' ') : ''\n  }\n};"
      },
