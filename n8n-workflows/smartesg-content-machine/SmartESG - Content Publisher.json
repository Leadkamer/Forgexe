    {
      "parameters": {
        "jsCode": "// APPROVE: combineer post + author + media voor de Unipile-call\nconst post = $('Get Post Row').first().json;\nconst body = $('Dashboard Webhook').first().json.body;\nconst authorRows = $('Get Authors').all();\nconst authorRow = authorRows.find(r => (r.json.author || '').trim() === (post.author || '').trim());\n\nconst media = body.media || null;\nconst imageUrl = (media && media.url) ? media.url : (body.image_url || '');\nconst isVideo = !!(media && media.kind === 'video');\n\nreturn {\n  json: {\n    post_id: post.id,\n    author: post.author,\n    final_post_tekst: body.edited_post_tekst || post.post_tekst,\n    unipile_account_id: authorRow ? authorRow.json.unipile_account_id : '',\n    row_number: post.row_number,\n    image_url: imageUrl,\n    image_mime: media ? (media.mime || '') : '',\n    image_name: media ? (media.name || '') : '',\n    has_image: !!imageUrl,\n    is_video: isVideo\n  }\n};"
      },
