    {
      "parameters": {
        "jsCode": "// Parse + scoreer lead\nconst b = $json.body || {};\n\nconst answers = {\n  q_relevant: (b.q_relevant || '').trim(),\n  q_iso9001: (b.q_iso9001 || '').trim(),\n  q_iso14001: (b.q_iso14001 || '').trim(),\n  q_ecovadis: (b.q_ecovadis || '').trim(),\n  q_keten: (b.q_keten || '').trim()\n};\n\n// Tier berekenen\nfunction isActief(v) {\n  return ['Gecertificeerd','Al gecertificeerd','In uitvoering','Ja, ambitie','Al aangesloten','Van plan','Ja, essentieel','Op termijn','Ja, urgent','Ja, oriënterend'].includes(v);\n}\nconst activeCount = Object.values(answers).filter(isActief).length;\n\nlet tier = 'COLD';\nif (answers.q_relevant === 'Ja, urgent' && answers.q_keten === 'Ja, essentieel') {\n  tier = 'HOT';\n} else if (answers.q_relevant === 'Ja, urgent') {\n  tier = 'WARM';\n} else if (answers.q_relevant === 'Ja, oriënterend' && activeCount >= 3) {\n  tier = 'WARM';\n}\n\n// Voornaam + email validatie\nconst voornaam = (b.voornaam || '').trim();\nconst email = (b.email || '').trim().toLowerCase();\nconst isValidEmail = /^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$/.test(email);\n\nreturn {\n  json: {\n    voornaam,\n    achternaam: (b.achternaam || '').trim(),\n    naam: voornaam + ' ' + (b.achternaam || '').trim(),\n    email,\n    bedrijf: (b.bedrijf || '').trim(),\n    functie: (b.functie || '').trim(),\n    ...answers,\n    consent: !!b.consent,\n    source: b.source || 'leveranciersbeoordeling-landing',\n    submitted_at: b.submitted_at || new Date().toISOString(),\n    submitted_date: (b.submitted_at || new Date().toISOString()).substring(0,10),\n    page_url: b.page_url || '',\n    tier,\n    active_count: activeCount,\n    is_valid: isValidEmail && voornaam.length > 0\n  }\n};"
      },
