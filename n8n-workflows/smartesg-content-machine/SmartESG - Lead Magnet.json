      "parameters": {
        "sendTo": "info@smartesg.nl",
        "subject": "=🔥 Nieuwe lead-magnet download ({{ $('Parse + Score Lead').first().json.tier }}): {{ $('Parse + Score Lead').first().json.naam }} - {{ $('Parse + Score Lead').first().json.bedrijf }}",
        "emailType": "html",
        "message": "=<!DOCTYPE html><html><body style=\"font-family:Arial,sans-serif;line-height:1.6;color:#0f172a;max-width:600px;margin:0 auto;padding:20px;\">\n<h2>Nieuwe leadmagnet-download — Tier: <span style=\"color:{{ $('Parse + Score Lead').first().json.tier === 'HOT' ? '#dc2626' : ($('Parse + Score Lead').first().json.tier === 'WARM' ? '#f59e0b' : '#64748b') }}\">{{ $('Parse + Score Lead').first().json.tier }}</span></h2>\n\n<table cellpadding=\"6\" style=\"width:100%;border-collapse:collapse;\">\n  <tr><td><strong>Naam</strong></td><td>{{ $('Parse + Score Lead').first().json.naam }}</td></tr>\n  <tr><td><strong>Email</strong></td><td><a href=\"mailto:{{ $('Parse + Score Lead').first().json.email }}\">{{ $('Parse + Score Lead').first().json.email }}</a></td></tr>\n  <tr><td><strong>Bedrijf</strong></td><td>{{ $('Parse + Score Lead').first().json.bedrijf }}</td></tr>\n  <tr><td><strong>Functie</strong></td><td>{{ $('Parse + Score Lead').first().json.functie || '-' }}</td></tr>\n  <tr><td colspan=\"2\" style=\"padding-top:14px;\"><strong>Antwoorden:</strong></td></tr>\n  <tr><td>Relevant?</td><td>{{ $('Parse + Score Lead').first().json.q_relevant }}</td></tr>\n  <tr><td>ISO 9001</td><td>{{ $('Parse + Score Lead').first().json.q_iso9001 }}</td></tr>\n  <tr><td>ISO 14001</td><td>{{ $('Parse + Score Lead').first().json.q_iso14001 }}</td></tr>\n  <tr><td>EcoVadis</td><td>{{ $('Parse + Score Lead').first().json.q_ecovadis }}</td></tr>\n  <tr><td>Ketenrapportage</td><td>{{ $('Parse + Score Lead').first().json.q_keten }}</td></tr>\n</table>\n\n<p style=\"margin-top:20px;padding:12px;background:#f0fdf4;border-left:4px solid #0f766e;\">\n{{ $('Parse + Score Lead').first().json.tier === 'HOT' ? '🔥 <strong>HOT lead</strong> — direct opvolgen, urgentie + ketenrapportage interesse.' : ($('Parse + Score Lead').first().json.tier === 'WARM' ? '🌤 <strong>WARM lead</strong> — toevoegen aan FU-sequence.' : '❄️ <strong>COLD lead</strong> — nieuwsbrief, niet sales-opvolgen.') }}\n</p>\n</body></html>",
        "options": {}
      },
