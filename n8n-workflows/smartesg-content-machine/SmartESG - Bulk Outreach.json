    {
      "parameters": {
        "jsCode": "// Filter eligible leads + verdeel over Tom/Bas tot daglimiet\nconst leads = $input.all().map(i => i.json);\nconst cfg = $('Merge Config').first().json;\nconst daglimiet = cfg.pitch_daglimiet || 20;\n\n// Welke display-statussen zijn geselecteerd via dashboard?\nconst selectedStatuses = (cfg.pitch_statuses || 'Geaccepteerd,Follow-up,Nudge')\n  .split(',')\n  .map(s => s.trim())\n  .filter(s => s);\n\n// Spiegel van dashboard's getStatus() - bepaalt display-status van een lead\nfunction displayStatus(l) {\n  if ((l['Heeft Gereageerd'] || '').trim() === 'Ja') return 'Gereageerd';\n  if ((l['Status Follow-up'] || '').trim() === 'Nudge Verzonden') return 'Nudge';\n  if ((l['Status Follow-up'] || '').trim() === 'Verzonden') return 'Follow-up';\n  return (l.Status || 'Nieuw').trim();\n}\n\nfunction isEligible(l) {\n  if ((l['Pitch Verzonden'] || '').trim() !== '') return false;\n  if (!l.provider_id && !l['Provider ID'] && !l.providerId) return false;\n  return selectedStatuses.includes(displayStatus(l));\n}\n\nconst tomQueue = leads.filter(l => isEligible(l) && (l.Afzender || '').trim() === 'Tom').slice(0, daglimiet);\nconst basQueue = leads.filter(l => isEligible(l) && (l.Afzender || '').trim() === 'Bas').slice(0, daglimiet);\n\nconst combined = [...tomQueue, ...basQueue];\n\nif (combined.length === 0) {\n  return [{ json: { empty: true, message: 'Geen eligible leads vandaag', remaining: 0, selectedStatuses } }];\n}\n\nreturn combined.map(l => {\n  const voornaam = (l.Voornaam || '').trim() || 'daar';\n  const author = (l.Afzender || '').trim();\n  const accountId = author === 'Bas' ? 'REPLACE_WITH_BAS_UNIPILE_ID' : 'behhoyRSR5y24t66aDgVQQ';\n  const template = cfg.pitch_template || '';\n  const message = template.replace(/\\{Voornaam\\}/gi, voornaam).replace(/\\{voornaam\\}/gi, voornaam);\n  return {\n    json: {\n      linkedin_url: l['Linkedin URL'] || '',\n      voornaam: voornaam,\n      author: author,\n      account_id: accountId,\n      provider_id: l.provider_id || l['Provider ID'] || l.providerId || '',\n      message: message,\n      display_status: displayStatus(l),\n      empty: false\n    }\n  };\n});"
      },
