      "typeVersion": 1.2,
      "position": [64, 580],
      "id": "bulk-schedule",
      "name": "Schedule Daily 11:00"
    },
    {
      "parameters": {
        "jsCode": "// Webhook payload normaliseren. Actions: 'start' | 'stop' | 'send-now'\nconst body = $json.body || {};\nconst statuses = Array.isArray(body.statuses) ? body.statuses : [];\nreturn {\n  json: {\n    source: 'webhook',\n    action: body.action || 'start',\n    template: body.template || '',\n    daglimiet: body.daglimiet || 20,\n    throttle_sec: body.throttle_sec || 90,\n    statuses_csv: statuses.join(',')\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [288, 400],
      "id": "bulk-parse-webhook",
      "name": "Parse Webhook"
    },
    {
      "parameters": {
        "jsCode": "// Schedule trigger - alleen op werkdagen processen\nconst today = new Date();\nconst dow = today.getDay();\nif (dow === 0 || dow === 6) return [];\nreturn [{ json: { source: 'schedule', action: 'send-now' } }];"
      },
