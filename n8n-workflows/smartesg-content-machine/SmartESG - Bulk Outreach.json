    {
      "parameters": {
        "jsCode": "// Bouw settings object uit key/value rows. Merge met webhook input indien aanwezig.\nconst rows = $('Get Settings').all().map(i => i.json);\nconst settings = {};\nrows.forEach(r => { if (r.key) settings[r.key] = r.value; });\n\n// Detecteer of we via webhook of schedule kwamen\nlet trigger = {};\ntry { trigger = $('Parse Webhook').first().json; } catch(e) {}\nif (!trigger.action) {\n  try { trigger = $('Werkdag Check').first().json; } catch(e) {}\n}\n\nconst webhookTemplate = (trigger.template || '').trim();\nconst webhookDaglimiet = parseInt(trigger.daglimiet) || 0;\nconst webhookThrottle = parseInt(trigger.throttle_sec) || 0;\nconst webhookStatusesCsv = (trigger.statuses_csv || '').trim();\n\nreturn {\n  json: {\n    source: trigger.source || 'unknown',\n    action: trigger.action || 'send-now',\n    pitch_actief: (settings.pitch_actief || 'Nee').trim(),\n    pitch_template: webhookTemplate || (settings.pitch_template || ''),\n    pitch_daglimiet: webhookDaglimiet || parseInt(settings.pitch_daglimiet) || 20,\n    pitch_throttle_sec: webhookThrottle || parseInt(settings.pitch_throttle_sec) || 90,\n    pitch_statuses: webhookStatusesCsv || (settings.pitch_statuses || 'Geaccepteerd,Follow-up,Nudge'),\n    template_came_from_webhook: !!webhookTemplate,\n    statuses_came_from_webhook: !!webhookStatusesCsv\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [736, 490],
      "id": "bulk-merge-config",
      "name": "Merge Config"
    },
